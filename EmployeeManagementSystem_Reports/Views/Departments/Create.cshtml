@model EmployeeManagementSystem_Reports.Models.Department

@{
    ViewBag.Title = "Create Department";
}

<div class="container mt-4">

    <div class="card shadow p-4">

        <h3 class="mb-4">Create Department</h3>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <!-- Department Name -->
            <div class="mb-3">
                @Html.LabelFor(m => m.DepartmentName, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.DepartmentName, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.DepartmentName, "", new { @class = "text-danger" })
            </div>

            <!-- Manager Name -->
            <div class="mb-4">
                @Html.LabelFor(m => m.ManagerName, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.ManagerName, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.ManagerName, "", new { @class = "text-danger" })
            </div>

            <!-- Buttons -->
            <button type="submit" class="btn btn-primary">
                Create
            </button>

            @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary ms-2" })
        }

    </div>

</div>