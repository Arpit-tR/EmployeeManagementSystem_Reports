@model EmployeeManagementSystem_Reports.Models.Department

@{
    ViewBag.Title = "Department Details";
}

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow p-4">

                <h3 class="mb-4 text-center">Department Details</h3>

                <div class="mb-3">
                    <label class="form-label fw-bold">Department Name</label>
                    <div class="form-control">
                        @Model.DepartmentName
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Manager Name</label>
                    <div class="form-control">
                        @Model.ManagerName
                    </div>
                </div>

                <div class="d-flex justify-content-between">

                    <a href="@Url.Action("Edit", new { id = Model.DepartmentId })"
                       class="btn btn-primary">
                        Edit
                    </a>

                    <a href="@Url.Action("Index")"
                       class="btn btn-secondary">
                        Back
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>