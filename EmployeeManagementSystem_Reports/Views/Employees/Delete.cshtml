@model EmployeeManagementSystem_Reports.Models.Employee

@{
    ViewBag.Title = "Delete Employee";
}

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow p-4 border-danger">

                <h3 class="text-danger text-center mb-3">
                     Delete Employee
                </h3>

                <p class="text-center text-muted mb-4">
                    Are you sure you want to delete this employee?
                </p>

                <div class="mb-3">
                    <label class="form-label fw-bold">Name</label>
                    <div class="form-control">@Model.Name</div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Email</label>
                    <div class="form-control">@Model.Email</div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Department</label>
                    <div class="form-control">
                        @Model.Department.DepartmentName
                    </div>
                </div>

                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()

                    <div class="d-flex justify-content-between">

                        <input type="submit"
                               value="Delete"
                               class="btn btn-danger" />

                        <a href="@Url.Action("Index")"
                           class="btn btn-secondary">
                            Cancel
                        </a>

                    </div>
                }

            </div>

        </div>

    </div>

</div>